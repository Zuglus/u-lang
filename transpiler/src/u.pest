// U Language Grammar

program = { SOI ~ NEWLINE* ~ (statement ~ (NEWLINE+ | &EOI))* ~ EOI }

// Statements
statement = { memory_stmt | use_stmt | pub_lifecycle_def | lifecycle_def | pub_struct_def | struct_def | pub_type_def | type_def | trait_def | impl_block | test_fn_def | pub_fn_def | fn_def | for_loop | while_loop | loop_stmt | if_stmt | match_stmt | select_stmt
            | spawn_stmt | return_stmt | break_stmt | continue_stmt | mutation_stmt | assignment | expr_stmt }

test_fn_def    = { test_kw ~ fn_def }
pub_fn_def     = { pub_kw ~ fn_def }
pub_struct_def    = { pub_kw ~ struct_def }
pub_type_def      = { pub_kw ~ type_def }
pub_lifecycle_def = { pub_kw ~ lifecycle_def }

lifecycle_def = { struct_kw ~ identifier ~ NEWLINE+ ~ born_clause ~ lives_clause ~ dies_clause? ~ end_kw }
born_clause    = { born_with_body | born_simple }
born_simple    = { born_kw ~ ":" ~ typed_field ~ NEWLINE+ }
born_with_body = { born_kw ~ "(" ~ typed_field ~ ")" ~ NEWLINE+ ~ born_body }
born_body      = { (!lives_kw ~ statement ~ NEWLINE+)* }
lives_clause  = { lives_kw ~ NEWLINE+ ~ block }
dies_clause   = { dies_kw ~ ":" ~ expr_stmt ~ NEWLINE+ }
born_kw       = @{ "born"  ~ !(LETTER | ASCII_DIGIT | "_") }
lives_kw      = @{ "lives" ~ !(LETTER | ASCII_DIGIT | "_") }
dies_kw       = @{ "dies"  ~ !(LETTER | ASCII_DIGIT | "_") }

memory_stmt = { memory_kw ~ "(" ~ identifier ~ ")" }
use_stmt    = { use_kw ~ use_path ~ ":" ~ use_items }
use_path    = @{ (LETTER | "_") ~ (LETTER | ASCII_DIGIT | "_" | ".")* }
use_items   = { identifier ~ ("," ~ identifier)* }

struct_def  = { struct_kw ~ identifier ~ type_params? ~ NEWLINE+ ~ (typed_field ~ NEWLINE+)* ~ end_kw }
type_def    = { enum_kw ~ identifier ~ type_params? ~ NEWLINE+ ~ (type_variant ~ NEWLINE+)* ~ end_kw }
type_params = { "[" ~ identifier ~ ("," ~ identifier)* ~ "]" }
trait_def        = { trait_kw ~ identifier ~ NEWLINE+ ~ (trait_method_sig ~ NEWLINE+)* ~ end_kw }
trait_method_sig = { fn_kw ~ identifier ~ "(" ~ fn_params? ~ ")" ~ fn_ret? }
impl_block       = { impl_kw ~ identifier ~ (for_kw ~ identifier)? ~ NEWLINE+ ~ (fn_def ~ NEWLINE+)* ~ end_kw }
fn_def      = { fn_kw ~ identifier ~ "(" ~ fn_params? ~ ")" ~ fn_ret? ~ NEWLINE+ ~ block ~ end_kw }
for_loop    = { for_kw ~ for_pattern ~ in_kw ~ expression ~ NEWLINE+ ~ block ~ end_kw }
loop_stmt   = { loop_kw ~ NEWLINE+ ~ block ~ end_kw }
if_stmt     = { if_kw ~ expression ~ NEWLINE+ ~ block ~ elif_clause* ~ else_clause? ~ end_kw }
match_stmt  = { match_kw ~ expression ~ NEWLINE+ ~ (match_arm ~ NEWLINE+)* ~ end_kw }
select_stmt = { select_kw ~ NEWLINE+ ~ (select_case ~ NEWLINE+)* ~ end_kw }
select_case = { case_kw ~ expression ~ "=>" ~ expr_stmt }
spawn_stmt    = { spawn_kw ~ expression }
return_stmt   = { return_kw ~ expression? }
break_stmt    = { break_kw }
continue_stmt = { continue_kw }
while_loop    = { while_kw ~ expression ~ NEWLINE+ ~ block ~ end_kw }
mutation_stmt = { identifier ~ "." ~ identifier ~ "=" ~ expression }
assignment  = { identifier ~ "=" ~ expression }
expr_stmt   = { expression }

// Function params with optional types
fn_params = { fn_param ~ ("," ~ fn_param)* }
fn_param   = { mut_marker? ~ identifier ~ (":" ~ identifier)? }
mut_marker = { mut_kw }
fn_ret    = { "->" ~ type_name }
type_name = @{ identifier ~ ("[" ~ type_name ~ ("," ~ type_name)* ~ "]")? }

// Struct / type fields
typed_field  = { identifier ~ ":" ~ type_name }
type_variant = { identifier ~ ("(" ~ (typed_field ~ ("," ~ typed_field)*)? ~ ")")? }

// Match — supports variant, string, list patterns, and wildcard
match_arm       = { match_pattern ~ "=>" ~ match_arm_body }
match_pattern   = { list_pattern | match_wildcard | variant_pattern | string_literal }
list_pattern    = { list_empty | list_single | list_cons }
list_empty      = { "[" ~ "]" }
list_single     = { "[" ~ identifier ~ "]" }
list_cons       = { "[" ~ identifier ~ "," ~ ".." ~ identifier ~ "]" }
variant_pattern = { none_literal | none_cap_pattern | identifier ~ ("(" ~ match_bindings? ~ ")")? }
none_literal    = @{ "none" ~ !(LETTER | ASCII_DIGIT | "_") }
none_cap_pattern = @{ "None" ~ !(LETTER | ASCII_DIGIT | "_") }
match_bindings  = { identifier ~ ("," ~ identifier)* }
match_wildcard  = @{ "_" ~ !(LETTER | ASCII_DIGIT | "_") }
match_arm_body  = _{ return_stmt | assignment | expr_stmt }

// Blocks and patterns
block         = { (statement ~ NEWLINE+)* }
param_list    = { identifier ~ ("," ~ identifier)* }
for_pattern   = { tuple_pattern | identifier }
tuple_pattern = { "(" ~ identifier ~ ("," ~ identifier)+ ~ ")" }

// If clauses
elif_clause = { elif_kw ~ expression ~ NEWLINE+ ~ block }
else_clause = { else_kw ~ NEWLINE+ ~ block }

// Expressions — precedence from low to high
expression     = { logical }
logical        = { comparison ~ (logical_op ~ comparison)* }
comparison     = { addition ~ (comp_op ~ addition)? }
addition       = { multiplication ~ (add_op ~ multiplication)* }
multiplication = { unary ~ (mul_op ~ unary)* }
unary          = { prefix_op* ~ operand }
operand        = { primary ~ suffix* }
suffix         = _{ NEWLINE* ~ method_call | NEWLINE* ~ field_access | index_access | postfix_op }
index_access   = { "[" ~ expression ~ "]" }
primary        = { lambda | struct_init | function_call | raw_string_literal | string_literal | number | bool_literal
                 | none_literal | paren_expr | list_literal | identifier }

// Operators
comp_op    = { ">=" | "<=" | "!=" | "==" | ">" | "<" }
add_op     = { "+" | "-" }
mul_op     = { "*" | "/" | "%" }
prefix_op  = { "-" | not_kw }
logical_op = { and_kw | or_kw }
not_kw     = @{ "not" ~ !(LETTER | ASCII_DIGIT | "_") }
and_kw     = @{ "and" ~ !(LETTER | ASCII_DIGIT | "_") }
or_kw      = @{ "or" ~ !(LETTER | ASCII_DIGIT | "_") }

// Expression parts
lambda          = { fn_kw ~ "(" ~ param_list? ~ ")" ~ expression }
struct_init     = { identifier ~ "(" ~ named_arg_list ~ ")" }
named_arg_list  = { named_arg ~ ("," ~ named_arg)* }
named_arg       = { identifier ~ ":" ~ expression }
function_call   = { identifier ~ "(" ~ arg_list? ~ ")" }
method_call     = { "." ~ identifier ~ "(" ~ arg_list? ~ ")" }
field_access    = { "." ~ identifier }
postfix_op      = { "?" | bang_op }
bang_op         = @{ "!" ~ !"=" }
paren_expr      = { "(" ~ expression ~ ")" }
list_literal    = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
arg_list        = { expression ~ ("," ~ expression)* }

// String with interpolation
string_literal = ${ "\"" ~ string_part* ~ "\"" }
string_part    =  { interp_expr | interp_var | string_text | dollar_lit }
interp_expr    = ${ "$(" ~ interp_raw ~ ")" }
interp_raw     = @{ (!")" ~ !"(" ~ ANY | "(" ~ interp_raw ~ ")")* }
interp_var     = ${ "$" ~ identifier }
string_text    = @{ (!("\"" | "$") ~ ANY)+ }
dollar_lit     = @{ "$" }

// Raw strings: #"..."#, ##"..."##
raw_string_literal = ${ raw_string_2 | raw_string_1 }
raw_string_1       = ${ "#\"" ~ raw_1_part* ~ "\"#" }
raw_1_part         =  { interp_expr | interp_var | raw_1_text | dollar_lit }
raw_1_text         = @{ (!("\"#" | "$") ~ ANY)+ }
raw_string_2       = ${ "##\"" ~ raw_2_part* ~ "\"##" }
raw_2_part         =  { interp_expr | interp_var | raw_2_text | dollar_lit }
raw_2_text         = @{ (!("\"##" | "$") ~ ANY)+ }

// Entry point for re-parsing interpolation expressions outside compound-atomic context
expression_entry = { SOI ~ expression ~ EOI }

// Atoms
identifier   = @{ !keyword ~ (LETTER | "_") ~ (LETTER | ASCII_DIGIT | "_")* }
keyword      = _{ ("if" | "elif" | "else" | "end" | "for" | "while" | "fn" | "process" | "return"
                 | "true" | "false" | "and" | "or" | "not" | "in" | "match" | "struct" | "thing"
                 | "enum" | "trait" | "impl" | "use" | "memory" | "pub" | "unsafe"
                 | "weak" | "test" | "spawn" | "loop" | "pass" | "mut" | "break"
                 | "continue" | "none") ~ !(LETTER | ASCII_DIGIT | "_") }
bool_literal = @{ ("true" | "false") ~ !(LETTER | ASCII_DIGIT | "_") }
number       = @{ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }

// Keyword terminals (atomic to prevent WHITESPACE between keyword and boundary check)
fn_kw     = @{ ("fn" | "process") ~ !(LETTER | ASCII_DIGIT | "_") }
for_kw    = @{ "for" ~ !(LETTER | ASCII_DIGIT | "_") }
in_kw     = @{ "in" ~ !(LETTER | ASCII_DIGIT | "_") }
if_kw     = @{ "if" ~ !(LETTER | ASCII_DIGIT | "_") }
elif_kw   = @{ "elif" ~ !(LETTER | ASCII_DIGIT | "_") }
else_kw   = @{ "else" ~ !(LETTER | ASCII_DIGIT | "_") }
end_kw    = @{ "end" ~ !(LETTER | ASCII_DIGIT | "_") }
return_kw = @{ "return" ~ !(LETTER | ASCII_DIGIT | "_") }
struct_kw = @{ "struct" ~ !(LETTER | ASCII_DIGIT | "_") }
enum_kw   = @{ "enum" ~ !(LETTER | ASCII_DIGIT | "_") }
match_kw  = @{ "match" ~ !(LETTER | ASCII_DIGIT | "_") }
select_kw = @{ "select" ~ !(LETTER | ASCII_DIGIT | "_") }
spawn_kw  = @{ "spawn" ~ !(LETTER | ASCII_DIGIT | "_") }
loop_kw   = @{ "loop" ~ !(LETTER | ASCII_DIGIT | "_") }
memory_kw = @{ "memory" ~ !(LETTER | ASCII_DIGIT | "_") }
use_kw    = @{ "use" ~ !(LETTER | ASCII_DIGIT | "_") }
trait_kw  = @{ "trait" ~ !(LETTER | ASCII_DIGIT | "_") }
impl_kw   = @{ "impl" ~ !(LETTER | ASCII_DIGIT | "_") }
test_kw     = @{ "test" ~ !(LETTER | ASCII_DIGIT | "_") }
mut_kw      = @{ "mut" ~ !(LETTER | ASCII_DIGIT | "_") }
break_kw    = @{ "break" ~ !(LETTER | ASCII_DIGIT | "_") }
continue_kw = @{ "continue" ~ !(LETTER | ASCII_DIGIT | "_") }
case_kw     = @{ "case" ~ !(LETTER | ASCII_DIGIT | "_") }
while_kw    = @{ "while" ~ !(LETTER | ASCII_DIGIT | "_") }
pub_kw      = @{ "pub" ~ !(LETTER | ASCII_DIGIT | "_") }

// Implicit rules
NEWLINE    = _{ "\r\n" | "\n" | "\r" }
WHITESPACE = _{ " " | "\t" }
COMMENT    = _{ "//" ~ (!NEWLINE ~ ANY)* }
