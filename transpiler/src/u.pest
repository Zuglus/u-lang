// U Language Grammar

program = { SOI ~ NEWLINE* ~ (statement ~ (NEWLINE+ | &EOI))* ~ EOI }

// Statements
statement = { struct_def | type_def | fn_def | for_loop | if_stmt | match_stmt
            | return_stmt | mutation_stmt | assignment | expr_stmt }

struct_def  = { struct_kw ~ identifier ~ NEWLINE+ ~ (typed_field ~ NEWLINE+)* ~ end_kw }
type_def    = { type_kw ~ identifier ~ NEWLINE+ ~ (type_variant ~ NEWLINE+)* ~ end_kw }
fn_def      = { fn_kw ~ identifier ~ "(" ~ fn_params? ~ ")" ~ fn_ret? ~ NEWLINE+ ~ block ~ end_kw }
for_loop    = { for_kw ~ for_pattern ~ in_kw ~ expression ~ NEWLINE+ ~ block ~ end_kw }
if_stmt     = { if_kw ~ expression ~ NEWLINE+ ~ block ~ elif_clause* ~ else_clause? ~ end_kw }
match_stmt  = { match_kw ~ expression ~ NEWLINE+ ~ (match_arm ~ NEWLINE+)* ~ end_kw }
return_stmt = { return_kw ~ expression? }
mutation_stmt = { operand ~ "::" ~ identifier ~ "=" ~ expression }
assignment  = { identifier ~ "=" ~ expression }
expr_stmt   = { expression }

// Function params with optional types
fn_params = { fn_param ~ ("," ~ fn_param)* }
fn_param  = { identifier ~ (":" ~ identifier)? }
fn_ret    = { ":" ~ identifier }

// Struct / type fields
typed_field  = { identifier ~ ":" ~ identifier }
type_variant = { identifier ~ "(" ~ typed_field ~ ("," ~ typed_field)* ~ ")" }

// Match — supports variant, string, and wildcard patterns
match_arm       = { match_pattern ~ ":" ~ match_arm_body }
match_pattern   = { variant_pattern | string_literal | match_wildcard }
variant_pattern = { identifier ~ "(" ~ match_bindings? ~ ")" }
match_bindings  = { identifier ~ ("," ~ identifier)* }
match_wildcard  = @{ "_" ~ !(LETTER | ASCII_DIGIT | "_") }
match_arm_body  = _{ return_stmt | assignment | expr_stmt }

// Blocks and patterns
block         = { (statement ~ NEWLINE+)* }
param_list    = { identifier ~ ("," ~ identifier)* }
for_pattern   = { tuple_pattern | identifier }
tuple_pattern = { "(" ~ identifier ~ ("," ~ identifier)+ ~ ")" }

// If clauses
elif_clause = { elif_kw ~ expression ~ NEWLINE+ ~ block }
else_clause = { else_kw ~ NEWLINE+ ~ block }

// Expressions — precedence from low to high
expression     = { comparison }
comparison     = { addition ~ (comp_op ~ addition)? }
addition       = { multiplication ~ (add_op ~ multiplication)* }
multiplication = { unary ~ (mul_op ~ unary)* }
unary          = { prefix_op* ~ operand }
operand        = { primary ~ suffix* }
suffix         = _{ NEWLINE* ~ method_call | NEWLINE* ~ field_access | postfix_op }
primary        = { lambda | struct_init | function_call | string_literal | number | bool_literal
                 | paren_expr | list_literal | identifier }

// Operators
comp_op    = { ">=" | "<=" | "!=" | "==" | ">" | "<" }
add_op     = { "+" | "-" }
mul_op     = { "*" | "/" | "%" }
prefix_op  = { "-" | not_kw }
not_kw     = @{ "not" ~ !(LETTER | ASCII_DIGIT | "_") }

// Expression parts
lambda        = { fn_kw ~ "(" ~ param_list? ~ ")" ~ expression }
struct_init   = { identifier ~ "(" ~ named_arg_list ~ ")" }
named_arg_list = { named_arg ~ ("," ~ named_arg)* }
named_arg     = { identifier ~ ":" ~ expression }
function_call = { identifier ~ "(" ~ arg_list? ~ ")" }
method_call   = { "." ~ identifier ~ "(" ~ arg_list? ~ ")" }
field_access  = { "." ~ identifier }
postfix_op    = { "?" | bang_op }
bang_op       = @{ "!" ~ !"=" }
paren_expr    = { "(" ~ expression ~ ")" }
list_literal  = { "[" ~ (expression ~ ("," ~ expression)*)? ~ "]" }
arg_list      = { expression ~ ("," ~ expression)* }

// String with interpolation
string_literal = ${ "\"" ~ string_part* ~ "\"" }
string_part    =  { interp_expr | interp_var | string_text | dollar_lit }
interp_expr    = ${ "$(" ~ interp_raw ~ ")" }
interp_raw     = @{ (!")" ~ !"(" ~ ANY | "(" ~ interp_raw ~ ")")* }
interp_var     = ${ "$" ~ identifier }
string_text    = @{ (!("\"" | "$") ~ ANY)+ }
dollar_lit     = @{ "$" }

// Entry point for re-parsing interpolation expressions outside compound-atomic context
expression_entry = { SOI ~ expression ~ EOI }

// Atoms
identifier   = @{ !keyword ~ (LETTER | "_") ~ (LETTER | ASCII_DIGIT | "_")* }
keyword      = _{ ("if" | "elif" | "else" | "end" | "for" | "while" | "fn" | "return"
                 | "true" | "false" | "and" | "or" | "not" | "in" | "match" | "struct"
                 | "type" | "trait" | "impl" | "use" | "memory" | "public" | "unsafe"
                 | "weak" | "test" | "spawn" | "loop" | "pass") ~ !(LETTER | ASCII_DIGIT | "_") }
bool_literal = @{ ("true" | "false") ~ !(LETTER | ASCII_DIGIT | "_") }
number       = @{ ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)? }

// Keyword terminals (atomic to prevent WHITESPACE between keyword and boundary check)
fn_kw     = @{ "fn" ~ !(LETTER | ASCII_DIGIT | "_") }
for_kw    = @{ "for" ~ !(LETTER | ASCII_DIGIT | "_") }
in_kw     = @{ "in" ~ !(LETTER | ASCII_DIGIT | "_") }
if_kw     = @{ "if" ~ !(LETTER | ASCII_DIGIT | "_") }
elif_kw   = @{ "elif" ~ !(LETTER | ASCII_DIGIT | "_") }
else_kw   = @{ "else" ~ !(LETTER | ASCII_DIGIT | "_") }
end_kw    = @{ "end" ~ !(LETTER | ASCII_DIGIT | "_") }
return_kw = @{ "return" ~ !(LETTER | ASCII_DIGIT | "_") }
struct_kw = @{ "struct" ~ !(LETTER | ASCII_DIGIT | "_") }
type_kw   = @{ "type" ~ !(LETTER | ASCII_DIGIT | "_") }
match_kw  = @{ "match" ~ !(LETTER | ASCII_DIGIT | "_") }

// Implicit rules
NEWLINE    = _{ "\r\n" | "\n" | "\r" }
WHITESPACE = _{ " " | "\t" }
COMMENT    = _{ "//" ~ (!NEWLINE ~ ANY)* }
