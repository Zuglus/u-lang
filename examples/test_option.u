// test_option.u — тест Option через str_to_int

num_str = "42"
maybe_num = num_str.to_int()

// Match на Option
match maybe_num
    Some(n) => print("Got number")
    None => print("No number")
end

// Не валидная строка
bad_str = "not_a_number"
bad_num = bad_str.to_int()

match bad_num
    Some(n) => print("Bad got number")
    None => print("Bad got None")
end

print("Done!")
