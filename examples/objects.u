// objects.u — методы через impl

struct Counter
    value: Int
end

impl Counter
    fn new() -> Counter
        return Counter(value: 0)
    end
    
    fn get(self) -> Int
        return self.value
    end
    
    fn increment(mut self)
        self.value = self.value + 1
    end
end

c = Counter.new()
print("Start: $(c.get())")

c.increment()
c.increment()
c.increment()

print("Result: $(c.get())")