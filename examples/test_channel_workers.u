# Тест 9: Worker pattern
# Проверяет: распределение работы между горутинами

work_ch = Channel.new()
result_ch = Channel.new()

# Worker 1
spawn(fn()
    task = work_ch.receive()
    result_ch.send(task * 2)
end)

# Worker 2  
spawn(fn()
    task = work_ch.receive()
    result_ch.send(task * 3)
end)

work_ch.send(10)
work_ch.send(10)

r1 = result_ch.receive()
r2 = result_ch.receive()
print("Test 9 - Workers: $r1, $r2")
# Ожидается: 20 и 30 (порядок может меняться)
