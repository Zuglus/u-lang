// shapes.u — структуры и match

struct Point
    x: Int
    y: Int
end

enum Shape
    Circle(radius: Int)
    Rect(width: Int, height: Int)
end

fn area(shape: Shape) -> Int
    match shape
        Circle(r) => return r * r * 3
        Rect(w, h) => return w * h
    end
end

p = Point(x: 10, y: 20)
print("Point: $(p.x), $(p.y)")

print("Circle: $(area(Circle(radius: 5)))")
print("Rect: $(area(Rect(width: 3, height: 4)))")