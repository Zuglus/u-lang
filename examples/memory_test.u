// memory_test.u — проверка циклических ссылок в интерпретаторе
//
// Вопрос: может ли интерпретатор обрабатывать циклические ссылки?
// Гипотеза: Value — по значению (Clone), циклы невозможны,
//           каждая мутация работает с копией.

// --- Тест 1: Parent/Child (обратная ссылка) ---

struct Parent
    name: String
    child: String
end

struct Child
    name: String
    parent: String
end

test fn test_parent_child()
    p = Parent(name: "parent", child: none)
    c = Child(name: "child", parent: p)
    p::child = c
    // p.child — это КОПИЯ c, сделанная в момент p::child = c
    // c.parent — это КОПИЯ p, сделанная в момент c = Child(..., parent: p)
    assert_eq(p.child.name, "child")
    assert_eq(c.parent.name, "parent")
    print("parent/child: ok")
end

// --- Тест 2: двусвязный список ---

struct Node
    value: Int
    next: Int
    prev: Int
end

test fn test_linked_list()
    a = Node(value: 1, next: none, prev: none)
    b = Node(value: 2, next: none, prev: none)
    c = Node(value: 3, next: none, prev: none)
    a::next = b
    b::prev = a
    b::next = c
    c::prev = b
    assert_eq(a.next.value, 2)
    assert_eq(b.prev.value, 1)
    assert_eq(b.next.value, 3)
    print("linked list: ok")
end

// --- Тест 3: кольцо (проверка глубины копий) ---

test fn test_ring()
    a = Node(value: 1, next: none, prev: none)
    b = Node(value: 2, next: none, prev: none)
    c = Node(value: 3, next: none, prev: none)
    a::next = b
    b::next = c
    c::next = a
    // Если by-value: a.next = копия b (когда b.next ещё none)
    // Значит a.next.next = none, а не c
    // Если by-reference: a.next.next.next.value == 1 (кольцо)
    assert_eq(a.next.value, 2)
    assert_eq(b.next.value, 3)
    assert_eq(c.next.value, 1)
    // Этот тест проверяет: a.next.next — это none или Node?
    // Если none — значит by-value (копии, нет циклов)
    print("ring: checking a.next.next...")
    print(a.next.next)
end

// --- Тест 4: мутация после копирования ---

test fn test_mutation_isolation()
    a = Node(value: 1, next: none, prev: none)
    b = Node(value: 2, next: none, prev: none)
    a::next = b
    // Теперь меняем b — отражается ли в a.next?
    b::value = 999
    // Если by-value: a.next.value == 2 (копия не затронута)
    // Если by-reference: a.next.value == 999
    assert_eq(b.value, 999)
    assert_eq(a.next.value, 2)
    print("mutation isolation: ok — a.next.value всё ещё 2")
end

// --- Тест 5: взаимные друзья ---

struct Person
    name: String
    friend: String
end

test fn test_friends()
    a = Person(name: "Андрей", friend: none)
    b = Person(name: "Иван", friend: none)
    a::friend = b
    b::friend = a
    assert_eq(a.friend.name, "Иван")
    assert_eq(b.friend.name, "Андрей")
    // a.friend — копия b (когда b.friend ещё none)
    // b.friend — копия a (когда a.friend = копия b)
    // Проверка: a.friend.friend — это none или что-то?
    print("friends: a.friend.friend = $(a.friend.friend)")
    print("friends: b.friend.friend.name = $(b.friend.friend.name)")
    print("friends: ok")
end
