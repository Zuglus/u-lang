struct Operation
    name: String
    a: Int
    b: Int
end

enum Maybe[T]
    Being(value: T)
    Nothing(op: Operation)
end

fn divide(a: Int, b: Int) -> Maybe[Int]
    if b == 0
        return Nothing(op: Operation(name: "divide", a: a, b: b))
    end
    return Being(value: a / b)
end

result = divide(10, 0)

match result
    Being(v) => print("Being: $v")
    Nothing(op) => print("Ничто: операция divide")
end
