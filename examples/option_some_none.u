enum Option[T]
    Some(value: T)
    None
end

fn safe_div(a: Int, b: Int) -> Option[Int]
    if b == 0
        return None
    end
    return Some(value: a / b)
end

result = safe_div(10, 2)
fail = safe_div(10, 0)

match result
    Some(v) => print("Some: $v")
    None => print("None")
end

match fail
    Some(v) => print("Some: $v")
    None => print("None")
end
