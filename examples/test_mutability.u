// === ПРАВИЛА МУТАБЕЛЬНОСТИ ===

// 1. ПЕРЕМЕННЫЕ — immutable (неизменяемые)
x = 10
// x = 20      // ❌ ОШИБКА: нельзя переопределить переменную

// 2. ПОЛЯ СТРУКТУР — mutable (изменяемые)
struct Counter
    value: Int
end

c = Counter(value: 0)
c.value = 10      // ✅ РАБОТАЕТ: меняем поле

print("value = $(c.value)")
