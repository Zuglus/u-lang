// test_result.u — Result через функции (альтернативные имена)

enum MyResult
    Val(value: Int)
    Fail(msg: String)
end

fn is_ok(r: MyResult) -> Bool
    match r
        Val(v) => return true
        Fail(e) => return false
    end
end

fn is_err(r: MyResult) -> Bool
    match r
        Val(v) => return false
        Fail(e) => return true
    end
end

fn unwrap(r: MyResult) -> Int
    match r
        Val(v) => return v
        Fail(e) => return 0
    end
end

fn unwrap_or(r: MyResult, default: Int) -> Int
    match r
        Val(v) => return v
        Fail(e) => return default
    end
end

fn divide(a: Int, b: Int) -> MyResult
    if b == 0
        Fail(msg: "division by zero")
    else
        Val(value: a / b)
    end
end

fn main()
    r1 = divide(10, 2)
    r2 = divide(10, 0)
    
    print("r1 is_ok: ")
    print(is_ok(r1))
    
    print("r1 is_err: ")
    print(is_err(r1))
    
    print("r2 is_ok: ")
    print(is_ok(r2))
    
    print("r2 is_err: ")
    print(is_err(r2))
    
    print("r1 unwrap: ")
    print(unwrap(r1))
    
    print("r2 unwrap_or(-1): ")
    print(unwrap_or(r2, -1))
    
    print("Done!")
end
