// ТЕСТ: Можно ли использовать переменную после передачи?

// Создаём список
data = [1, 2, 3]
print("1. Создали список")

// Передаём в функцию
result = process(data)
print("2. После process(data): результат = $result")

// Пробуем использовать data снова
print("3. Используем data снова:")
for x in data
    print("   $x")
end

// Пробуем ещё раз!
result2 = process(data)
print("4. После ВТОРОГО process(data): результат = $result2")

fn process(items)
    print("   Внутри process")
    // Просто возвращаем длину через итерацию
    count = 0
    for x in items
        count = count + 1
    end
    return count
end
