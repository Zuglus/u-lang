// Тест: что реально происходит

// Создаём список
data = [1, 2, 3]

// Передаём в функцию
n = get_first(data)

// Используем data снова
print("Original: $data")
print("First was: $n")

fn get_first(items: List) -> Int
    // Здесь items — это КОПИЯ списка
    // Генератор делает: items.clone() при вызове
    return items.first()
end
