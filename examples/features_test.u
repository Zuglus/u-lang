// list methods
data = [3, 1, 4, 1, 5]
print("sum: $(data.sum())")
filtered = data.filter(fn(x) x > 2)
print("filter count: $(filtered.len())")
doubled = data.map(fn(x) x * 2)
print("first doubled: $(doubled[0])")
print("last doubled: $(doubled[4])")

// break, continue
for i in range(0, 10)
    if i == 3
        continue
    end
    if i == 7
        break
    end
    print(i)
end

// indexing
print("data[0] = $(data[0])")
print("data[2] = $(data[2])")

// unary minus
y = -5
print(y)
print(-y)

// float
f = 3.14
print(f)
n = 42
print(float(n))
