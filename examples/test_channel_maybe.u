# Тест 10: Being/Nothing через канал
# Проверяет: передача Maybe типа через канал

enum Maybe[T]
    Being(value: T)
    Nothing(phantom: Phantom[T])
end

ch = Channel.new()

spawn(fn()
    success = Being(value: 42)
    ch.send(success)
end)

result = ch.receive()
match result
    Being(v) => print("Test 10 - Maybe in channel: Being($v)")
    Nothing(p) => print("Test 10 - Nothing received")
end
# Ожидается: Being(42)
