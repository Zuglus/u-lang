// web.u — простой веб-сервер

use simple_server: serve

fn handler(path) -> String
    if path == "/"
        return "<h1>Hello from U!</h1><p>Root page</p>"
    elif path == "/about"
        return "<h1>About</h1><p>U-lang web server</p>"
    else
        return "<h1>404</h1><p>Page not found</p>"
    end
end

print("Starting server...")
serve(":8080", handler)