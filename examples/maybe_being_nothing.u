enum Maybe[T]
    Being(value: T)
    Nothing
end

fn divide(a: Int, b: Int) -> Maybe[Int]
    if b == 0
        return Nothing
    end
    return Being(value: a / b)
end

result = divide(10, 2)
fail = divide(10, 0)

match result
    Being(v) => print("Being: $v")
    Nothing => print("Nothing")
end

match fail
    Being(v) => print("Being: $v")
    Nothing => print("Nothing")
end
