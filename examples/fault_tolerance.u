// fault_tolerance.u — spawn автоматически ловит паники

fn risky_worker(id: Int, ch: Channel)
    msg = ch.recv()
    if msg == "crash"
        msg.int()!    // "crash" не число → ! → паника
    end
    print("Worker $id: processed $msg")
end

ch = Channel.new()
spawn risky_worker(1, ch)
spawn risky_worker(2, ch)
spawn risky_worker(3, ch)
ch.send("task A")
ch.send("crash")
ch.send("task B")
sleep(500)
print("All workers done, server still running")
