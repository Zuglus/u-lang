// server.u — HTTP-сервер для статических файлов (keep-alive)

use std.http: HttpServer

fn handle(conn: HttpConn)
    loop
        path = conn.path()
        if path == ""
            return
        end
        if path == "/"
            path = "/index.html"
        end
        file = read_file("public$(path)")
        match file
            Ok(content) => conn.respond(Response.ok(content, mime_type(path)))
            Err(_) => conn.respond(Response.not_found("404 Not Found"))
        end
    end
end

server = HttpServer.listen(":3000")?
print("Serving static files from ./public on http://localhost:3000")

loop
    conn = server.accept()?
    spawn handle(conn)
end
