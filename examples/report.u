// report.u — одноразовая задача: отчёт по зарплатам

struct Report
    born: file: String
    lives
        data = parse_csv(file)
        by_dept = data.group_by(row => row.department)
        for dept, rows in by_dept
            avg = rows.avg(r => r.salary)
            print("$dept: средняя зарплата $(avg.round(2))")
        end
    dies
end

Report("workers.csv").run()
