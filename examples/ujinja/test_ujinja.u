use ujinja: render

// простая подстановка
data = #"{"name": "Андрей", "age": 30}"#
result = render("Привет, {{ name }}!", data, "ru")
print(result)

// вложенный доступ
data2 = #"{"hero": {"title": {"ru": "Заголовок", "en": "Title"}}}"#
result2 = render("{{ hero.title.ru }}", data2, "ru")
print(result2)

// цикл
data3 = #"{"items": [{"name": "Один"}, {"name": "Два"}, {"name": "Три"}]}"#
tmpl = #"{% for item in items %}<li>{{ item.name }}</li>{% endfor %}"#
result3 = render(tmpl, data3, "ru")
print(result3)

// условие
data4 = #"{"lang": "ru"}"#
tmpl2 = #"{% if lang == "ru" %}Привет{% else %}Hello{% endif %}"#
result4 = render(tmpl2, data4, "ru")
print(result4)
