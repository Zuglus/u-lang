# Тест 5: Передача структуры
# Проверяет: передача пользовательской структуры через канал

struct Point
    x: Int
    y: Int
end

ch = Channel.new()

spawn(fn()
    p = Point(x: 10, y: 20)
    ch.send(p)
end)

result = ch.receive()
print("Test 5 - Struct transfer: Point($result.x, $result.y)")
# Ожидается: Point(10, 20)
